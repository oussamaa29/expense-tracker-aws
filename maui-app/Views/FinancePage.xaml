<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ExpenseTracker.ViewModels"
             xmlns:models="clr-namespace:ExpenseTracker.Models"
             x:Class="ExpenseTracker.Views.FinancePage"
             x:DataType="vm:FinanceViewModel"
             Title="File de Révision"
             BackgroundColor="#0F0F1A">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Déconnexion" Clicked="OnLogoutClicked" />
    </ContentPage.ToolbarItems>

    <ContentPage.BindingContext>
        <vm:FinanceViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*">

        <!-- Bandeau d'erreur -->
        <Label Grid.Row="0"
               Text="{Binding ErrorMessage}"
               BackgroundColor="#3E1010"
               TextColor="#FF6B6B"
               Padding="12"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

        <RefreshView Grid.Row="1"
                     Command="{Binding LoadExpensesCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Expenses}"
                            EmptyView="Aucune dépense en attente de révision.">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ExpenseReport">
                        <Border Margin="12,5"
                                BackgroundColor="#1A1A2E"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#2E2E50"
                                Padding="16,14">
                            <VerticalStackLayout Spacing="10">

                                <!-- Employé & Montant -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding EmployeeId}"
                                           FontSize="12"
                                           TextColor="#6E6E8F"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1"
                                           Text="{Binding FormattedAmount}"
                                           FontAttributes="Bold"
                                           FontSize="17"
                                           TextColor="#4FC3F7" />
                                </Grid>

                                <!-- Catégorie & Date -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding CategoryLabel}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Grid.Column="1"
                                           Text="{Binding FormattedDate}"
                                           FontSize="12"
                                           TextColor="#6E6E8F" />
                                </Grid>

                                <!-- Description -->
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="#9E9EBF"
                                       LineBreakMode="TailTruncation" />

                                <!-- Badge statut -->
                                <Border BackgroundColor="{Binding StatusColor}"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        Padding="10,3"
                                        HorizontalOptions="Start">
                                    <Label Text="{Binding StatusLabel}"
                                           FontSize="11"
                                           TextColor="White"
                                           FontAttributes="Bold" />
                                </Border>

                                <BoxView HeightRequest="1" BackgroundColor="#2E2E50" />

                                <!-- Boutons d'action -->
                                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            Text="✓ Approuver"
                                            BackgroundColor="#2E7D32"
                                            TextColor="White"
                                            CornerRadius="8"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FinanceViewModel}}, Path=ApproveCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Grid.Column="1"
                                            Text="✗ Rejeter"
                                            BackgroundColor="#C62828"
                                            TextColor="White"
                                            CornerRadius="8"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FinanceViewModel}}, Path=RejectCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Grid.Column="2"
                                            Text="→"
                                            BackgroundColor="#252540"
                                            TextColor="#4FC3F7"
                                            CornerRadius="8"
                                            FontSize="16"
                                            WidthRequest="48"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FinanceViewModel}}, Path=OpenDetailCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
