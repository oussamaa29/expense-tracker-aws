<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTracker.Views.ExpenseDetailPage"
             Title="Détail de la Dépense">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Loading Indicator -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="True"
                               IsVisible="True"
                               Color="#2196F3"
                               HorizontalOptions="Center" />

            <!-- Content Card -->
            <Border x:Name="ContentCard"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#E0E0E0"
                    Padding="20"
                    IsVisible="False">
                <VerticalStackLayout Spacing="14">

                    <!-- Status Badge -->
                    <HorizontalStackLayout HorizontalOptions="Center">
                        <Border x:Name="StatusBadge"
                                StrokeShape="RoundRectangle 16"
                                Padding="16,6">
                            <Label x:Name="StatusLabel"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   TextColor="White" />
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Separator -->
                    <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />

                    <!-- Details -->
                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Montant" TextColor="#757575" FontSize="14" />
                        <Label Grid.Row="0" Grid.Column="1" x:Name="AmountLabel" FontAttributes="Bold" FontSize="18" TextColor="#212121" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Catégorie" TextColor="#757575" FontSize="14" />
                        <Label Grid.Row="1" Grid.Column="1" x:Name="CategoryLabel" FontSize="14" TextColor="#212121" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Description" TextColor="#757575" FontSize="14" />
                        <Label Grid.Row="2" Grid.Column="1" x:Name="DescriptionLabel" FontSize="14" TextColor="#212121" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Créée le" TextColor="#757575" FontSize="14" />
                        <Label Grid.Row="3" Grid.Column="1" x:Name="DateLabel" FontSize="14" TextColor="#212121" />

                        <Label Grid.Row="4" Grid.Column="0" Text="Employé" TextColor="#757575" FontSize="14" />
                        <Label Grid.Row="4" Grid.Column="1" x:Name="EmployeeLabel" FontSize="13" TextColor="#616161" />
                    </Grid>

                    <!-- Reject Comment -->
                    <Border x:Name="RejectCommentBox"
                            BackgroundColor="#FFEBEE"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#EF9A9A"
                            Padding="12"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Commentaire du reviewer" FontAttributes="Bold" TextColor="#C62828" FontSize="13" />
                            <Label x:Name="RejectCommentLabel" TextColor="#B71C1C" FontSize="13" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Receipt Section -->
                    <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />
                    <Label Text="Reçu" FontAttributes="Bold" FontSize="15" TextColor="#424242" />

                    <!-- Receipt Image -->
                    <Image x:Name="ReceiptImage"
                           HeightRequest="250"
                           Aspect="AspectFit"
                           IsVisible="False" />

                    <ActivityIndicator x:Name="ReceiptLoading"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="#2196F3"
                                       HorizontalOptions="Center" />

                    <Label x:Name="NoReceiptLabel"
                           Text="Aucun reçu attaché."
                           TextColor="#9E9E9E"
                           FontSize="13"
                           HorizontalOptions="Center" />

                    <!-- Upload Button -->
                    <Button x:Name="UploadReceiptButton"
                            Text="📎 Joindre un justificatif"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            CornerRadius="8"
                            Clicked="OnUploadReceiptClicked"
                            IsVisible="False" />

                    <!-- Submit Draft Button (employee only, draft expense) -->
                    <Button x:Name="SubmitDraftButton"
                            Text="Soumettre"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            CornerRadius="8"
                            Clicked="OnSubmitDraftClicked"
                            IsVisible="False" />

                    <!-- Resubmit Button (employee only, rejected expense) -->
                    <Button x:Name="ResubmitButton"
                            Text="Resoumettre"
                            BackgroundColor="#FF9800"
                            TextColor="White"
                            CornerRadius="8"
                            Clicked="OnResubmitClicked"
                            IsVisible="False" />

                    <!-- Finance action buttons (finance only, submitted expense) -->
                    <Grid x:Name="FinanceActionBar"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="10"
                          IsVisible="False">
                        <Button Grid.Column="0"
                                Text="Approuver"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                CornerRadius="8"
                                Clicked="OnApproveClicked" />
                        <Button Grid.Column="1"
                                Text="Rejeter"
                                BackgroundColor="#F44336"
                                TextColor="White"
                                CornerRadius="8"
                                Clicked="OnRejectClicked" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
